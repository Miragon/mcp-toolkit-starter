{
  "name": "my-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "Minimal MCP server built on @miragon/mcp-toolkit: one host, one module with its own tools, one widget.",
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env src/host.ts",
    "build:bundle": "vite build --config app-bundle/vite.config.ts",
    "start": "pnpm run build:bundle && pnpm run dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@miragon/mcp-toolkit-core": "0.7.0",
    "@miragon/mcp-toolkit-proxy-contract": "0.7.0",
    "@miragon/mcp-toolkit-ui": "0.7.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "mcp-use": "1.33.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-singlefile": "2.3.3"
  }
}
